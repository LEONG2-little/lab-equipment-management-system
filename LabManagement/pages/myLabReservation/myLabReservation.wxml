<!--pages/myLabReservation/myLabReservation.wxml-->
<view class="reservation-container">
  <view wx:if="{{reservationArr.length>0}}">
    <view wx:for="{{reservationArr}}" wx:key="lab_reservation_id" data-index="{{index}}" class="reservation-item">

      <view class="info-area" bindtap="toReservationDetail" data-index="{{index}}">
        <view class="info-item">
          <text class="label">实验室名称：</text>
          <text class="value">{{item.lab_detail.laboratory_name || '未知'}}</text>
        </view>

        <view class="info-item">
          <text class="label">使用用途：</text>
          <text class="value">{{item.purpose}}</text>
        </view>

        <view class="info-item">
          <text class="label">状态：</text>
          <text class="value">{{item.status}}</text>
        </view>
      </view>

      <view class="button-area">
        <button class="return-btn" bindtap="returnLab" data-index="{{index}}">取消预约</button>
      </view>

    </view>
  </view>

  <view wx:else class="empty">
    <text>暂无预约信息</text>
  </view>

  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>

  <!-- 给底部栏留出空间 -->
  <view class="tabbar-placeholder"></view>
</view>