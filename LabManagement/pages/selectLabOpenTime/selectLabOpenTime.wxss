/* pages/selectLabOpenTime/selectLabOpenTime.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.week-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  min-width: 93%;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #409eff;
}

.week-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.week-item {
  width: calc(25% - 15rpx);
  background-color: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 12rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.week-item.selected {
  background-color: #409eff;
  border-color: #409eff;
}

.week-item.selected .week-name {
  color: #fff;
}

.week-name {
  font-size: 28rpx;
  color: #495057;
  font-weight: 500;
}

.selected-week-tip {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #409eff;
  text-align: right;
}

.time-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  min-width: 93%;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.time-item {
  background-color: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.time-item.selected {
  background-color: #409eff;
  border-color: #409eff;
}

.time-item.selected .time-label {
  color: #fff;
}

.time-label {
  font-size: 26rpx;
  color: #495057;
  font-weight: 500;
}

.selected-time-tip {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #409eff;
  text-align: right;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06a850 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(7, 193, 96, 0.2);
}

.tabbar-placeholder {
  height: 120rpx;
}