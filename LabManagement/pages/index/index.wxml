<!-- index.wxml -->
<view class="page-container">
  <!-- 功能菜单部分 -->
  <view class="menu-section">
    <!-- <view class="menu-item" bindtap="toAllDevice">
      <text>查看所有设备</text>
    </view> -->

    <view class="menu-item" bindtap="toFaultReport">
      <text>故障上报</text>
    </view>

    <view class="menu-item" bindtap="toReservation">
      <text>预约设备</text>
    </view>

    <view class="menu-item" bindtap="toLabReservation" wx:if="{{identity_type !== '学生'}}">
      <text>预约实验室</text>
    </view>
  </view>

  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="0"></custom-tabbar>

  <!-- 底部占位符，防止内容被遮挡 -->
  <view class="tabbar-placeholder"></view>
</view>