<!--pages/reservationDetail/reservationDetail.wxml-->
<!-- 引入 WXS -->
<wxs src="../../utils.wxs" module="utils" />

<view class="device-detail-container">
  <view class="device-card">

    <view class="info-item">
      <text class="info-label">设备名称：</text>
      <text class="info-value">{{deviceDetailArr.device_name || '未设置'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">设备分类：</text>
      <text class="info-value">{{deviceDetailArr.category || '未分类'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">设备型号：</text>
      <text class="info-value">{{deviceDetailArr.model || '未设置'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">规格参数：</text>
      <text class="info-value">{{deviceDetailArr.spec || '暂无规格参数'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">存放地点：</text>
      <text class="info-value">{{deviceDetailArr.location || '未设置地点'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">设备描述：</text>
      <text class="info-value">{{deviceDetailArr.description || '暂无描述'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">借用权限：</text>
      <text class="info-value">{{deviceDetailArr.required_permission}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">用途：</text>
      <text class="info-value">{{reservationDetailArr.purpose}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">预订使用时间为：</text>
      <text class="info-value">{{utils.formatDateTime(reservationDetailArr.start_time)}} 至 {{utils.formatDateTime(reservationDetailArr.end_time)}}</text>
    </view>

  </view>


  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>

  <!-- 给底部栏留出空间 -->
  <view class="tabbar-placeholder"></view>
</view>