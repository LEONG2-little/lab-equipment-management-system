/* pages/changeStatus/changeStatus.wxss */
.change-status-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.device-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.fault-textarea {
  width: 100%;
  min-height: 100rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
  background-color: transparent;
}

.info-item {
  display: flex;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 200rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
  word-break: break-all;
}

.action-area {
  padding: 20rpx 0;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: center;
}

.confirm-btn {
  background-color: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
  max-width: 400rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 0;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn:active {
  background-color: #096dd9;
  opacity: 0.9;
}

.tabbar-placeholder {
  height: 120rpx;
}

.picker-container {
  width: 100%;
}

.picker-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #333;
  font-size: 28rpx;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
  margin-left: 10rpx;
}