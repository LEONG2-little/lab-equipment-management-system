.personal-center-container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.user-info-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.info-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  background-color: #fafafa;
}

.button-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 20rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
}

.edit-btn {
  background-color: #409eff;
  color: #fff;
}

.password-btn {
  background-color: #fff;
  color: #409eff;
  border: 2rpx solid #409eff;
}

.confirm-btn {
  background-color: #67c23a;
  color: #fff;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
  border: 2rpx solid #ddd;
}

.action-btn:active {
  opacity: 0.8;
}

.tabbar-placeholder {
  height: 100rpx;
}