<!--pages/personalCenter/personalCenter.wxml-->
<view class="personal-center-container">
  
  <!-- 用户信息展示/编辑区域 -->
  <view class="user-info-card">
    <view class="info-item">
      <text class="info-label">账号：</text>
      <text class="info-value">{{userData.account}}</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">姓名：</text>
      <text class="info-value">{{userData.username}}</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">身份：</text>
      <text class="info-value">{{userData.identity_type}}</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">电话号码：</text>
      <input 
        wx:if="{{isEditing}}" 
        class="info-input" 
        value="{{editForm.phone}}" 
        bindinput="onPhoneInput"
        placeholder="请输入电话号码"
      />
      <text wx:else class="info-value">{{userData.phone || '未填写'}}</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">邮箱：</text>
      <input 
        wx:if="{{isEditing}}" 
        class="info-input" 
        value="{{editForm.email}}" 
        bindinput="onEmailInput"
        placeholder="请输入邮箱"
      />
      <text wx:else class="info-value">{{userData.email || '未填写'}}</text>
    </view>
    
    <view class="info-item">
      <text class="info-label">权限等级：</text>
      <text class="info-value">{{permission_level}}</text>
    </view>
  </view>
  
  <!-- 按钮区域 -->
  <view class="button-section">
    <!-- 非编辑状态显示两个按钮 -->
    <block wx:if="{{!isEditing}}">
      <button class="action-btn edit-btn" bindtap="startEdit">修改信息</button>
      <button class="action-btn password-btn" bindtap="toChangePassword">修改密码</button>
    </block>
    
    <!-- 编辑状态显示确认修改和取消按钮 -->
    <block wx:else>
      <button class="action-btn confirm-btn" bindtap="confirmUpdate">确认修改</button>
      <button class="action-btn cancel-btn" bindtap="cancelEdit">取消</button>
    </block>
  </view>
  
  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>
  
  <!-- 给底部栏留出空间 -->
  <view class="tabbar-placeholder"></view>
</view>