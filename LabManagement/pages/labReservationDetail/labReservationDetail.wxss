/* pages/labReservationDetail/labReservationDetail.wxss */
.lab-detail-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.lab-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  min-width: 160rpx;
  width: auto;
  flex-shrink: 0;
  font-weight: 500;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
  word-break: break-all;
}

.status-0 {
  color: #52c41a;
  font-weight: 600;
}

.status-1 {
  color: #1890ff;
  font-weight: 600;
}

.status-2 {
  color: #faad14;
  font-weight: 600;
}

.status-3 {
  color: #ff4d4f;
  font-weight: 600;
}

.tabbar-placeholder {
  height: 120rpx;
}