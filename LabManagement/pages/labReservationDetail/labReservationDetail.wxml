<!--pages/labReservationDetail/labReservationDetail.wxml-->
<!-- 引入 WXS -->
<wxs src="../../utils.wxs" module="utils" />

<view class="lab-detail-container">
  <view class="lab-card">

    <view class="info-item">
      <text class="info-label">实验室名称：</text>
      <text class="info-value">{{labDetailArr.laboratory_name || '未设置'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">实验室地点：</text>
      <text class="info-value">{{labDetailArr.location || '未设置'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">实验室描述：</text>
      <text class="info-value">{{labDetailArr.description || '暂无描述'}}</text>
    </view>

    <!-- 新增：显示实验室里的设备 -->
    <view class="info-item">
      <text class="info-label">其中的设备：</text>
      <text class="info-value">{{deviceNames || '加载中...'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">用途：</text>
      <text class="info-value">{{labReservationDetailArr.purpose}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">预订使用时间为：</text>
      <text class="info-value">{{utils.formatDateTime(labReservationDetailArr.start_time)}} 至 {{utils.formatDateTime(labReservationDetailArr.end_time)}}</text>
    </view>

    <view class="info-item" wx:if="{{labReservationDetailArr.return_at}}">
      <text class="info-label">完成时间：</text>
      <text class="info-value">{{utils.formatDateTime(labReservationDetailArr.return_at)}}</text>
    </view>

  </view>

  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>

  <!-- 给底部栏留出空间 -->
  <view class="tabbar-placeholder"></view>
</view>