<!--pages/myAllReservation/myAllReservation.wxml-->
<view class="page-container">
  <!-- 功能菜单部分 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="toMyReservation">
      <text>我的设备预约</text>
    </view>

    <view class="menu-item" bindtap="toMyLabReservation">
      <text>我的实验室预约</text>
    </view>

  </view>

  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>

  <!-- 底部占位符，防止内容被遮挡 -->
  <view class="tabbar-placeholder"></view>
</view>