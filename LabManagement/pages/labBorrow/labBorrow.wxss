/* pages/labBorrow/labBorrow.wxss */
.page-wrapper {
  width: 100vw;
  height: 100vh;
  margin: 0;
  padding: 0;
}

.container {
  padding: 20rpx;
  padding-bottom: -37rpx;
  padding-top: 30rpx;
  height: calc(100vh - 30rpx - -37rpx);
  overflow-y: auto;
  overflow-x: hidden;
  box-sizing: border-box;
}

.search-bar-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background-color: #fff;
  padding: 20rpx 20rpx 0 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%; 
}

.search-input-wrapper {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 40rpx;
  line-height: 40rpx;
  min-width: 0;
}

.status-picker {
  background-color: #e0e0e0;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #333;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

.picker-arrow {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

.search-result-tip {
  font-size: 26rpx;
  color: #666;
  padding: 20rpx 10rpx;
  background-color: #fff;
  margin-top: 10rpx;
}

.lab-list {
  width: 100%;
}

.lab-item {
  width: 90vw; 
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: flex-start;
  position: relative;
  z-index: 0;
}

.lab-info {
  flex: 1;
  margin-bottom: 0;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.info-row .label {
  color: #666;
  min-width: 70rpx;
  width: auto;
  flex-shrink: 0;
}

.info-row .value {
  color: #333;
  flex: 1;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.lab-item:last-child {
  margin-bottom: 120rpx; 
}

.tabbar-placeholder {
  height: 100rpx;
}