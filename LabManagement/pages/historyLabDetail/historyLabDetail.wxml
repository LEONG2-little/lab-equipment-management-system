<!--pages/historyLabDetail/historyLabDetail.wxml-->
<!-- 引入 WXS -->
<wxs src="../../utils.wxs" module="utils" />

<view class="device-detail-container">
  <!-- 设备信息 -->
  <view class="device-card">

    <view class="info-item">
      <text class="info-label">名称：</text>
      <text class="info-value">{{labDetailArr.laboratory_name || '未设置'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">地点：</text>
      <text class="info-value">{{labDetailArr.location || '未设置'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">描述：</text>
      <text class="info-value">{{labDetailArr.description || '暂无描述'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">用途：</text>
      <text class="info-value">{{reservationDetailArr.purpose}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">状态：</text>
      <text class="info-value">{{reservationDetailArr.status}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">预订使用时间为：</text>
      <text class="info-value">{{utils.formatDateTime(reservationDetailArr.start_time)}} 至 {{utils.formatDateTime(reservationDetailArr.end_time)}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">归还时间为：</text>
      <text class="info-value">{{utils.formatDateTime(reservationDetailArr.return_at)}}</text>
    </view>

  </view>


  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>

  <!-- 给底部栏留出空间 -->
  <view class="tabbar-placeholder"></view>
</view>