<!--pages/register/register.wxml-->
<view class="register-container">
  <input type="text" placeholder="请输入真实姓名" value="{{user.username}}" bindinput="onInputName" />
  <input type="number" placeholder="请输入学号" value="{{user.account}}" bindinput="onInputAccount" />
  <input type="password" placeholder="请输入密码" value="{{user.password}}" bindinput="onInputPassword" />
  <input type="password" placeholder="请确认密码" value="{{confirmPassword}}" bindinput="onInputConfirmPassword" />

  <button type="primary" bindtap="register">注册</button>

  <view class="register-link" bindtap="goToLogin">已有账号？去登录</view>
</view>