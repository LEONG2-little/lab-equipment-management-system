<!--pages/faultReportFillOut/faultReportFillOut.wxml-->
<view class="fault-report-container">

  <view class="fault-card">

    <view class="info-item">
      <text class="info-label">设备名称：</text>
      <text class="info-value">{{deviceArr.device_name || '未设置'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">设备分类：</text>
      <text class="info-value">{{deviceArr.category || '未分类'}}</text>
    </view>

    <view class="info-item">
      <text class="info-label">设备地点：</text>
      <text class="info-value">{{deviceArr.location || '未设置地点'}}</text>
    </view>

    <view class="info-item textarea-area">
      <text class="info-label">故障描述：</text>
      <textarea class="info-textarea" placeholder="请详细描述故障现象（可填写多行内容）" value="{{reportData.description}}" bindinput="onInputDescription" auto-height maxlength="500" show-confirm-bar="{{false}}" />
    </view>

    <!-- 图片上传区域 -->
    <view class="info-item upload-area">
      <text class="info-label">故障图片：</text>
      <view class="upload-content">
        <!-- 未选择图片时显示加号按钮 -->
        <view wx:if="{{!faultImagePath}}" class="upload-btn" bindtap="chooseImage">
          <text class="plus-icon">+</text>
          <text class="upload-text">点击拍照</text>
        </view>
        <!-- 已选择图片时显示预览和删除 -->
        <view wx:else class="image-preview">
          <image src="{{faultImagePath}}" mode="widthFix" class="preview-img" bindtap="previewImage" catchtap="previewImage" />
          <view class="preview-mask" bindtap="deleteImage">
            <text class="delete-icon">×</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="action-area">
    <button class="report-btn" bindtap="faultReport">上报</button>
  </view>

  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>

  <!-- 给底部栏留出空间 -->
  <view class="tabbar-placeholder"></view>
</view>