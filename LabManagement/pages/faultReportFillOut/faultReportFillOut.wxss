/* pages/faultReportFillOut/faultReportFillOut.wxss */
.fault-report-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.fault-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.info-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 200rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
  word-break: break-all;
}

.textarea-area {
  align-items: flex-start;
  min-height: 200rpx; 
}

.info-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #e0e0e0;
  min-height: 180rpx;
  line-height: 1.6; 
  width: 100%; 
}

.info-textarea::placeholder {
  color: #999;
  font-size: 28rpx;
}

.action-area {
  padding: 20rpx 0;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: center;
}

.report-btn {
  background-color: #ff4d4f; 
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
  max-width: 400rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 0;
}

.report-btn::after {
  border: none;
}

.report-btn:active {
  background-color: #d9363e;
  opacity: 0.9;
}

.tabbar-placeholder {
  height: 120rpx;
}

.upload-area {
  align-items: flex-start;
}

.upload-content {
  flex: 1;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background-color: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.plus-icon {
  font-size: 80rpx;
  color: #999;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.preview-mask {
  position: absolute;
  top: 0;
  right: 0;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-bottom-left-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
}