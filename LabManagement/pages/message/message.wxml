<!--pages/message/message.wxml-->
<wxs src="../../utils.wxs" module="utils" />

<view class="container">
  
  <!-- 消息列表 -->
  <view class="message-list">

    <view wx:if="{{messageArr.length > 0}}">
      <view wx:for="{{messageArr}}" wx:key="notification_id" class="message-item {{item.is_read ? '' : 'unread'}}" data-index="{{index}}" bindtap="toMessageDetail">
        
        <view class="unread-dot {{item.is_read ? 'placeholder' : ''}}"></view>
        
        <view class="message-content">
          <view class="title-row">
            <text class="title">{{item.title}}</text>
            <text class="time">{{utils.formatDateTime(item.created_at)}}</text>
          </view>
          
          <view class="content">
            <text>{{item.content}}</text>
          </view>
        </view>
        
      </view>
    </view>
    
    <view wx:else class="empty-state">
      <view class="empty-icon">📭</view>
      <text class="empty-text">暂无消息</text>
    </view>
  </view>
  
  <!-- 自定义底部导航栏（固定定位） -->
  <custom-tabbar current="1"></custom-tabbar>
  
  <!-- 底部占位符，防止内容被遮挡 -->
  <view class="tabbar-placeholder"></view>
</view>