/* pages/myManage/myManage.wxss */
.page-container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f9f9f9;
}

.menu-section {
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.menu-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item::after {
  content: '';
  position: absolute;
  right: 30rpx;
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #999;
  border-right: 2rpx solid #999;
  transform: rotate(45deg);
}

.menu-item:active {
  background-color: #f5f5f5;
}

.tabbar-placeholder {
  height: 100rpx;
  width: 100%;
}