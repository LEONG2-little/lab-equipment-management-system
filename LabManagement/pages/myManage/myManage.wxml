<!--pages/myManage/myManage.wxml-->
<view class="page-container">
  <!-- 功能菜单部分 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="toMyDevice">
      <text>我管理的设备</text>
    </view>

    <view class="menu-item" bindtap="toMyLab">
      <text>我管理的实验室</text>
    </view>

    <view class="menu-item" bindtap="toDeviceBorrow">
      <text>设备借出情况</text>
    </view>

    <view class="menu-item" bindtap="toLabBorrow">
      <text>实验室借出情况</text>
    </view>

    <view class="menu-item" bindtap="toDeviceFaultHandling">
      <text>设备故障处理</text>
    </view>

    <view class="menu-item" bindtap="toLabFaultHandling">
      <text>实验室故障处理</text>
    </view>

  </view>

  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>

  <!-- 底部占位符，防止内容被遮挡 -->
  <view class="tabbar-placeholder"></view>
</view>