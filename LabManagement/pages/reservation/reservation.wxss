/* pages/myDevice/myDevice.wxss */
.page-wrapper {
  width: 100vw;
  height: 100vh;
  margin: 0;
  padding: 0;
}

.container {
  padding: 20rpx;
  padding-bottom: -37rpx;
  padding-top: 200rpx; 
  height: calc(100vh - 200rpx - -37rpx);
  overflow-y: auto;
  overflow-x: hidden;
  box-sizing: border-box;
}

.search-box {
  margin-bottom: 30rpx;
  position: fixed;
  top: -10rpx;
  left: 0; 
  right: 0; 
  z-index: 100; 
  background-color: #fff; 
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  
}

.search-input-wrapper {
  position: relative;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 40rpx;
  line-height: 40rpx;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

.search-result-tip {
  font-size: 26rpx;
  color: #666;
  padding: 20rpx;
  background-color: #fff;
  position: fixed;
  top: 150rpx; 
  left: 0;
  right: 0;
  z-index: 99;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  border-top: 1rpx solid #f0f0f0; 
}

.device-item {
  width: 90vw; 
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-top: 20rpx; 
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: flex-start;
  position: relative;
  z-index: 0;
}

.image-area {
  width: 160rpx;
  height: 160rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.device-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.device-info {
  flex: 1;
  margin-bottom: 0;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.info-row .label {
  color: #666;
  min-width: 10rpx; 
  width: auto; 
  flex-shrink: 0;
}

.info-row .value {
  color: #333;
  flex: 1;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.tabbar-placeholder {
  height: 100rpx;
}

.hint-text {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-top: 15rpx;
  padding: 0 20rpx;
}