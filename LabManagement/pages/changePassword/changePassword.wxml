<!--pages/changePassword/changePassword.wxml-->
<view class="change-password-container">
  
  <view class="form-card">
    <view class="input-group">
      <text class="input-label">原密码</text>
      <input 
        class="password-input" 
        type="password"
        password="{{true}}"
        value="{{oldPassword}}" 
        bindinput="onOldPasswordInput"
        placeholder="请输入原密码"
      />
    </view>
    
    <view class="input-group">
      <text class="input-label">新密码</text>
      <input 
        class="password-input" 
        type="password"
        password="{{true}}"
        value="{{newPassword}}" 
        bindinput="onNewPasswordInput"
        placeholder="请输入新密码（至少6位）"
      />
    </view>
    
    <view class="input-group">
      <text class="input-label">确认密码</text>
      <input 
        class="password-input" 
        type="password"
        password="{{true}}"
        value="{{confirmPassword}}" 
        bindinput="onConfirmPasswordInput"
        placeholder="请再次输入新密码"
      />
    </view>
  </view>
  
  <view class="button-section">
    <button class="submit-btn" bindtap="submitChangePassword">确认修改</button>
  </view>

  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>
  
  <!-- 给底部栏留出空间 -->
  <view class="tabbar-placeholder"></view>
</view>