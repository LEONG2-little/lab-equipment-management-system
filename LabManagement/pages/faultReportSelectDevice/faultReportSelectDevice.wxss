/* pages/faultReportSelectDevice/faultReportSelectDevice.wxss */

.reservation-container {
  padding: 20rpx;
}

.reservation-item {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.info-area {
  display: flex;
  flex-direction: row;
  align-items: flex-start; 
}

.image-area {
  width: 160rpx;
  height: 160rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.device-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}


.text-info-area {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item .label {
  color: #666;
  min-width: 10rpx;
  width: auto; 
  flex-shrink: 0;
}

.info-item .value {
  color: #333;
  flex: 1;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.tabbar-placeholder {
  height: 100rpx;
}