<!--pages/historySelect/historySelect.wxml-->
<view class="page-container">
  <!-- 功能菜单部分 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="toHistory">
      <text>设备预约历史</text>
    </view>

    <view class="menu-item" bindtap="toHistoryLab">
      <text>实验室预约历史</text>
    </view>

  </view>

  <!-- 自定义底部导航栏 -->
  <custom-tabbar current="4"></custom-tabbar>

  <!-- 底部占位符，防止内容被遮挡 -->
  <view class="tabbar-placeholder"></view>
</view>