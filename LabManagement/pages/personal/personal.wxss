/* pages/personal/personal.wxss */
.personal-container {
  padding: 20rpx;
}

.user-info {
  background-color: #f5f5f5;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-item .label {
  color: #666;
  width: 120rpx;
}

.info-item .value {
  color: #333;
  font-weight: normal;
}

.menu-section {
  background-color: #fff;
}

.menu-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 28rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.tabbar-placeholder {
  height: 100rpx;
}