/* pages/labFaultHandling/labFaultHandling.wxss */
.page-wrapper {
  width: 100vw;
  height: 100vh;
  margin: 0;
  padding: 0;
}

.container {
  padding: 20rpx;
  padding-bottom: -37rpx;
  padding-top: 30rpx;
  height: calc(100vh - 30rpx - -37rpx);
  overflow-y: auto;
  overflow-x: hidden;
  box-sizing: border-box;
}

.batch-btn {
  width: 200rpx !important;     
  min-width: 60rpx !important;
  height: 80rpx;
  line-height: 80rpx;
  background-color: rgb(133, 133, 133);
  color: #fff;
  font-size: 25rpx;
  border-radius: 20rpx;
  padding: 0 !important; 
  margin: 0;
  border: none;
  text-align: center;
  display: inline-block;  
}

.batch-btn::after {
  border: none;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

.device-list {
  width: 100%;
}

.device-item {
  width: 90vw; 
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: flex-start;
  position: relative;
  z-index: 0;
}

.image-area {
  width: 160rpx;
  height: 160rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.device-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.device-info {
  flex: 1;
  margin-bottom: 0;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.info-row .label {
  color: #666;
  min-width: 50rpx;
  width: auto;
  flex-shrink: 0;
}

.info-row .value {
  color: #333;
  flex: 1;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.checkbox-wrapper {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #999;
  border-radius: 8rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background-color: rgb(20, 238, 49);
  border-color: rgb(20, 238, 49);
}

.checkmark {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.device-item.selected {
  background-color: #f0f0f0;
}

.status-modify-btn {
  margin-top: 20rpx;
  padding-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
}

.status-modify-btn button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx; 
  background-color: rgb(133, 133, 133);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  margin: 0;
  padding: 0;
  text-align: center;
}

.status-modify-btn button::after {
  border: none;
}

.device-item:last-child {
  margin-bottom: 120rpx; 
}

.tabbar-placeholder {
  height: 100rpx;
}