<!--pages/messageDetail/messageDetail.wxml-->
<wxs src="../../utils.wxs" module="utils" />

<view class="container">
  
  <view class="detail-content">
    
    <view class="title-section">
      <text class="title">{{messageDetailArr.title || '无标题'}}</text>
    </view>
    
    <view class="time-section">
      <text class="time">{{utils.formatDateTime(messageDetailArr.created_at)}}</text>
    </view>
    
    <view class="divider"></view>
    
    <view class="content-section">
      <text class="content">{{messageDetailArr.content || '暂无内容'}}</text>
    </view>
    
  </view>
  
  <!-- 自定义底部导航栏（固定定位） -->
  <custom-tabbar current="4"></custom-tabbar>
  
  <!-- 底部占位符，防止内容被遮挡 -->
  <view class="tabbar-placeholder"></view>
</view>