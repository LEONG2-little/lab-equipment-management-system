/* components/custom-tabbar/custom-tabbar.wxss */
.custom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}

.icon-text {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.text {
  font-size: 22rpx;
  color: #999999;
}

.tab-item.active .text {
  color: #1296db;
}

/* 图标包装器，用于相对定位 */
.icon-wrapper {
  position: relative;
  display: inline-block;
}

/* 红点样式 */
.badge {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  min-width: 30rpx;
  height: 30rpx;
  background-color: #ff3b30;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

/* 红点中的数字 */
.badge-text {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
}